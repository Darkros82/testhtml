function getChoiceOpts(listId,key,cur) {
  const allVals=[...new Set(DATA[listId].map(r=>r[key]).filter(Boolean))];
  return allVals.map(v=>`<option ${v===cur?'selected':''}>${v}</option>`).join('');
}
function saveRec() {
  const cfg=LISTS[editList]; if(!cfg) return;
  const rec={};
  cfg.fields.forEach(f=>{const el=document.getElementById('ff-'+f.key);rec[f.key]=el?el.value.trim():''});
  if(!rec.titulo){toast('⚠ El nombre / título es obligatorio','warn');return}
  if(editId) {
    const i=DATA[editList].findIndex(r=>r.id===editId);
    if(i>=0) DATA[editList][i]={...DATA[editList][i],...rec};
    toast('✅ Registro actualizado','ok');
  } else {
    rec.id=Date.now().toString();
    DATA[editList].unshift(rec);
    toast('✅ Registro añadido','ok');
  }
  if(!SP.demo) saveToSP(editList,editId?DATA[editList].find(r=>r.id===editId):rec);
  cm('modal'); refreshCounts(); render();
}
function delRec(id,listId) {
  if(!confirm('¿Eliminar este registro?')) return;
  const r=DATA[listId].find(x=>x.id===id);
  DATA[listId]=DATA[listId].filter(x=>x.id!==id);
  if(!SP.demo&&r?._spId) deleteFromSP(listId,r._spId);
  refreshCounts(); render(); toast('🗑 Registro eliminado','ok');
}

