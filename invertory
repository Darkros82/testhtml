<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Inventario IT</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&display=swap" rel="stylesheet">
<style>
:root {
  --bg:#f0f2f5; --surface:#fff; --s2:#f8f9fb; --s3:#f0f2f5;
  --border:#e2e6ed; --border2:#c8cdd8;
  --text:#171b26; --sub:#5c6170; --muted:#9299a8;
  --blue:#2563eb; --blue-l:#eff4ff; --blue-d:#1d4ed8;
  --green:#15803d; --green-l:#f0fdf4;
  --amber:#b45309; --amber-l:#fffbeb;
  --red:#dc2626;   --red-l:#fef2f2;
  --purple:#7c3aed;--purple-l:#f5f3ff;
  --teal:#0f766e;  --teal-l:#f0fdfa;
  --orange:#c2410c;--orange-l:#fff7ed;
  --cyan:#0e7490;  --cyan-l:#ecfeff;
  --pink:#be185d;  --pink-l:#fdf2f8;
  --font:'DM Sans',sans-serif;
  --mono:'DM Mono',monospace;
  --r:6px; --r2:10px; --r3:14px;
  --sh:0 1px 3px rgba(0,0,0,.07),0 1px 2px rgba(0,0,0,.04);
  --sh2:0 8px 24px rgba(0,0,0,.12);
}
*{box-sizing:border-box;margin:0;padding:0}
body{background:var(--bg);color:var(--text);font-family:var(--font);font-size:14px;line-height:1.5;-webkit-font-smoothing:antialiased}

/* ── Shell ── */
.shell{display:flex;height:100vh;overflow:hidden}
.aside{width:232px;flex-shrink:0;background:var(--surface);border-right:1px solid var(--border);display:flex;flex-direction:column;overflow-y:auto}
.main-col{flex:1;display:flex;flex-direction:column;min-width:0;overflow:hidden}
.scroll-area{flex:1;overflow-y:auto;padding:22px 24px}

/* ── Sidebar ── */
.brand{display:flex;align-items:center;gap:10px;padding:15px 14px 13px;border-bottom:1px solid var(--border)}
.brand-icon{width:32px;height:32px;background:var(--blue);border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:16px;flex-shrink:0}
.brand-name{font-weight:700;font-size:14px;letter-spacing:-.2px;line-height:1.2}
.brand-env{font-size:10px;color:var(--muted);font-family:var(--mono)}
.nav-sec{padding:10px 8px 2px}
.nav-sec-lbl{font-size:10px;font-weight:600;color:var(--muted);letter-spacing:.8px;padding:5px 8px 3px;font-family:var(--mono)}
.ni{display:flex;align-items:center;gap:8px;padding:7px 9px;border-radius:var(--r);cursor:pointer;color:var(--sub);font-size:13px;font-weight:500;transition:all .1s;margin-bottom:1px}
.ni:hover{background:var(--s3);color:var(--text)}
.ni.on{background:var(--blue-l);color:var(--blue)}
.ni .ico{font-size:15px;width:18px;text-align:center;flex-shrink:0}
.ni .ct{margin-left:auto;font-size:10px;font-family:var(--mono);background:var(--s3);color:var(--muted);padding:1px 6px;border-radius:10px;min-width:18px;text-align:center}
.ni.on .ct{background:rgba(37,99,235,.1);color:var(--blue)}
.aside-foot{margin-top:auto;padding:10px;border-top:1px solid var(--border)}
.sp-pill{display:flex;align-items:center;gap:8px;padding:8px 10px;border-radius:var(--r2);background:var(--s3);border:1px solid var(--border);font-size:12px}
.sp-led{width:7px;height:7px;border-radius:50%;flex-shrink:0}
.sp-led.on{background:var(--green);box-shadow:0 0 0 2px rgba(21,128,61,.18)}
.sp-led.off{background:var(--muted)}
.sp-n{font-weight:600;font-size:12px;line-height:1.2}
.sp-u{font-size:10px;color:var(--muted);font-family:var(--mono)}

/* ── Topbar ── */
.topbar{display:flex;align-items:center;gap:10px;padding:11px 22px;background:var(--surface);border-bottom:1px solid var(--border);flex-shrink:0}
.tb-title{font-size:15px;font-weight:700;flex:1}
.tb-list-badge{font-size:11px;font-family:var(--mono);background:var(--blue-l);color:var(--blue);border:1px solid rgba(37,99,235,.2);padding:2px 8px;border-radius:4px;margin-left:6px}
.srch{position:relative}
.srch input{width:260px;padding:7px 11px 7px 32px;border:1px solid var(--border2);border-radius:var(--r);background:var(--s3);font-size:13px;font-family:var(--font);color:var(--text);outline:none;transition:all .15s}
.srch input:focus{border-color:var(--blue);box-shadow:0 0 0 3px rgba(37,99,235,.1);background:var(--surface)}
.srch input::placeholder{color:var(--muted)}
.srch-ico{position:absolute;left:9px;top:50%;transform:translateY(-50%);color:var(--muted);font-size:13px;pointer-events:none}
.btn{display:inline-flex;align-items:center;gap:5px;padding:7px 13px;border-radius:var(--r);border:1px solid var(--border2);background:var(--surface);color:var(--text);font-size:13px;font-family:var(--font);font-weight:500;cursor:pointer;transition:all .1s;white-space:nowrap;box-shadow:var(--sh)}
.btn:hover{background:var(--s3)}
.btn.pri{background:var(--blue);border-color:var(--blue);color:#fff;box-shadow:0 1px 3px rgba(37,99,235,.3)}
.btn.pri:hover{background:var(--blue-d)}
.btn.sm{padding:5px 9px;font-size:12px;box-shadow:none}
.btn.ghost{border-color:transparent;box-shadow:none;background:transparent}
.btn.ghost:hover{background:var(--s3)}
.btn.del:hover{color:var(--red);border-color:rgba(220,38,38,.3);background:var(--red-l)}

/* ── Filter bar ── */
.fbar{display:flex;align-items:center;gap:6px;padding:8px 22px;background:var(--surface);border-bottom:1px solid var(--border);flex-shrink:0;flex-wrap:wrap}
.fbar-lbl{font-size:10px;font-weight:600;color:var(--muted);font-family:var(--mono);margin-right:2px}
.fchip{display:inline-flex;align-items:center;gap:4px;padding:3px 10px;border-radius:20px;border:1px solid var(--border);background:var(--surface);font-size:12px;font-weight:500;cursor:pointer;transition:all .1s;color:var(--sub)}
.fchip:hover{border-color:var(--border2);color:var(--text)}
.fchip.on{border-width:1.5px}
.fchip[data-v="Portátil"].on{color:var(--blue);background:var(--blue-l);border-color:var(--blue)}
.fchip[data-v="Sobremesa"].on{color:var(--teal);background:var(--teal-l);border-color:var(--teal)}
.fchip[data-v="All-in-One"].on{color:var(--purple);background:var(--purple-l);border-color:var(--purple)}
.fchip[data-v="Servidor"].on{color:var(--amber);background:var(--amber-l);border-color:var(--amber)}
.fchip[data-v="Mac"].on{color:var(--sub);background:var(--s3);border-color:var(--border2)}
.fsel{padding:5px 8px;border:1px solid var(--border);border-radius:var(--r);font-size:12px;font-family:var(--font);color:var(--sub);background:var(--surface);outline:none;cursor:pointer}
.spc{flex:1}

/* ── Stats row ── */
.stats{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:20px}
.sc{background:var(--surface);border:1px solid var(--border);border-radius:var(--r2);padding:14px 16px;box-shadow:var(--sh);cursor:pointer;transition:border-color .15s}
.sc:hover{border-color:var(--border2)}
.sc-lbl{font-size:10px;font-weight:600;color:var(--muted);font-family:var(--mono);margin-bottom:4px;text-transform:uppercase;letter-spacing:.4px}
.sc-val{font-size:26px;font-weight:700;line-height:1;margin-bottom:2px}
.sc-sub{font-size:11px;color:var(--muted)}
.sc.blue .sc-val{color:var(--blue)}
.sc.green .sc-val{color:var(--green)}
.sc.amber .sc-val{color:var(--amber)}
.sc.red .sc-val{color:var(--red)}

/* ── Table ── */
.tc{background:var(--surface);border:1px solid var(--border);border-radius:var(--r2);box-shadow:var(--sh);overflow:hidden}
table{width:100%;border-collapse:collapse}
thead{background:var(--s2)}
th{padding:8px 13px;text-align:left;font-size:10px;font-weight:600;color:var(--muted);font-family:var(--mono);text-transform:uppercase;letter-spacing:.5px;border-bottom:1px solid var(--border);cursor:pointer;user-select:none;white-space:nowrap}
th:hover{color:var(--text)}
th.sk{color:var(--blue)}
td{padding:9px 13px;border-bottom:1px solid var(--border);font-size:13px;vertical-align:middle}
tr:last-child td{border-bottom:none}
tr:hover td{background:rgba(37,99,235,.015)}
.cell-name{font-weight:600;line-height:1.3}
.cell-name small{display:block;font-size:11px;color:var(--muted);font-weight:400;font-family:var(--mono);margin-top:1px}
.tipo-chip{display:inline-flex;align-items:center;padding:2px 8px;border-radius:4px;font-size:11px;font-weight:600;font-family:var(--mono)}
.tipo-Portátil{background:var(--blue-l);color:var(--blue)}
.tipo-Sobremesa{background:var(--teal-l);color:var(--teal)}
.tipo-All-in-One{background:var(--purple-l);color:var(--purple)}
.tipo-Servidor{background:var(--amber-l);color:var(--amber)}
.tipo-Mac{background:var(--s3);color:var(--sub);border:1px solid var(--border)}
.tipo-default{background:var(--s3);color:var(--sub)}
.mono-tag{font-family:var(--mono);font-size:11px;background:var(--s3);border:1px solid var(--border);border-radius:4px;padding:1px 6px;color:var(--cyan)}
.bitlocker-tag{font-family:var(--mono);font-size:10px;color:var(--green);background:var(--green-l);border:1px solid rgba(21,128,61,.2);border-radius:4px;padding:1px 5px;max-width:160px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;display:inline-block;cursor:help}
.row-acts{display:flex;gap:3px;opacity:0;transition:opacity .1s}
tr:hover .row-acts{opacity:1}
.ib{width:26px;height:26px;border-radius:5px;border:1px solid var(--border);background:transparent;color:var(--muted);cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:12px;transition:all .1s}
.ib:hover{background:var(--s3);color:var(--text);border-color:var(--border2)}
.ib.del:hover{color:var(--red);border-color:rgba(220,38,38,.3);background:var(--red-l)}
.empty{padding:50px;text-align:center;color:var(--muted)}
.empty .ei{font-size:36px;margin-bottom:10px;opacity:.4}
.pager{display:flex;align-items:center;justify-content:space-between;padding:9px 14px;border-top:1px solid var(--border);font-size:12px;color:var(--muted)}
.pager-btns{display:flex;gap:3px}
.pb{width:26px;height:26px;border-radius:5px;border:1px solid var(--border);background:transparent;color:var(--muted);cursor:pointer;font-size:12px;font-family:var(--font);transition:all .1s;display:flex;align-items:center;justify-content:center}
.pb:hover,.pb.on{background:var(--s3);color:var(--text);border-color:var(--border2)}
.pb.on{color:var(--blue);border-color:rgba(37,99,235,.3);background:var(--blue-l)}
.pb:disabled{opacity:.35;cursor:not-allowed}

/* ── Modal ── */
.ov{position:fixed;inset:0;background:rgba(10,15,30,.4);backdrop-filter:blur(4px);z-index:100;display:none;align-items:flex-start;justify-content:center;padding:36px 16px 36px;overflow-y:auto}
.ov.open{display:flex}
.mod{background:var(--surface);border:1px solid var(--border);border-radius:var(--r3);width:640px;max-width:100%;box-shadow:var(--sh2);animation:up .16s ease}
@keyframes up{from{transform:translateY(10px);opacity:0}}
.mh{display:flex;align-items:flex-start;justify-content:space-between;padding:18px 20px 14px;border-bottom:1px solid var(--border)}
.mh-t{font-size:16px;font-weight:700}
.mh-s{font-size:12px;color:var(--muted);margin-top:2px}
.mc{width:28px;height:28px;border-radius:6px;border:1px solid var(--border);background:transparent;color:var(--muted);cursor:pointer;font-size:16px;display:flex;align-items:center;justify-content:center;transition:all .1s;flex-shrink:0}
.mc:hover{background:var(--s3);color:var(--text)}
.mb{padding:18px 20px}
.mf{padding:12px 20px;border-top:1px solid var(--border);display:flex;justify-content:flex-end;gap:8px}
.fg{display:flex;flex-direction:column;gap:4px}
label.fl{font-size:10px;font-weight:600;color:var(--muted);font-family:var(--mono);text-transform:uppercase;letter-spacing:.4px}
input.fi,select.fi,textarea.fi{width:100%;padding:8px 11px;border:1px solid var(--border2);border-radius:var(--r);background:var(--s3);font-size:13px;font-family:var(--font);color:var(--text);outline:none;transition:all .15s}
input.fi:focus,select.fi:focus,textarea.fi:focus{border-color:var(--blue);box-shadow:0 0 0 3px rgba(37,99,235,.08);background:var(--surface)}
textarea.fi{resize:vertical;min-height:64px}
.fgrid{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.full{grid-column:1/-1}
.fsep{font-size:10px;font-weight:600;color:var(--muted);font-family:var(--mono);letter-spacing:.8px;padding:12px 0 4px;display:flex;align-items:center;gap:8px}
.fsep::after{content:'';flex:1;height:1px;background:var(--border)}

/* ── Detail modal ── */
.dmod .mod{width:720px}
.dgrid{display:grid;grid-template-columns:repeat(3,1fr);gap:9px}
.df{background:var(--s3);border-radius:var(--r);padding:9px 11px}
.df-k{font-size:9px;font-weight:600;color:var(--muted);font-family:var(--mono);text-transform:uppercase;letter-spacing:.4px;margin-bottom:3px}
.df-v{font-size:13px;font-weight:500}
.df.f2{grid-column:span 2}
.df.f3{grid-column:1/-1}

/* ── Auth ── */
#auth{position:fixed;inset:0;background:var(--bg);display:flex;align-items:center;justify-content:center;z-index:200}
.auth-wrap{background:var(--surface);border:1px solid var(--border);border-radius:var(--r3);padding:34px;width:400px;box-shadow:var(--sh2)}
.auth-head{display:flex;align-items:center;gap:11px;margin-bottom:6px}
.auth-icon{width:40px;height:40px;background:var(--blue);border-radius:9px;display:flex;align-items:center;justify-content:center;font-size:20px}
.auth-title{font-size:19px;font-weight:700;letter-spacing:-.3px}
.auth-sub{font-size:11px;color:var(--muted);font-family:var(--mono)}
.auth-desc{font-size:13px;color:var(--sub);line-height:1.6;margin:14px 0 18px}
.auth-field{margin-bottom:11px}
.auth-field label{display:block;font-size:10px;font-weight:600;color:var(--muted);font-family:var(--mono);text-transform:uppercase;letter-spacing:.4px;margin-bottom:4px}
.auth-field input{width:100%;padding:8px 11px;border:1px solid var(--border2);border-radius:var(--r);background:var(--s3);font-size:13px;font-family:var(--font);color:var(--text);outline:none;transition:all .15s}
.auth-field input:focus{border-color:var(--blue);box-shadow:0 0 0 3px rgba(37,99,235,.1);background:var(--surface)}
.auth-sep{display:flex;align-items:center;gap:10px;font-size:11px;color:var(--muted);margin:14px 0}
.auth-sep::before,.auth-sep::after{content:'';flex:1;height:1px;background:var(--border)}
.auth-btn{width:100%;padding:9px;background:var(--blue);border:none;border-radius:var(--r);color:#fff;font-size:14px;font-family:var(--font);font-weight:600;cursor:pointer;transition:background .1s}
.auth-btn:hover{background:var(--blue-d)}
.auth-btn.ghost{background:var(--surface);border:1px solid var(--border2);color:var(--text);box-shadow:var(--sh)}
.auth-btn.ghost:hover{background:var(--s3)}
.auth-err{font-size:12px;color:var(--red);background:var(--red-l);border:1px solid rgba(220,38,38,.2);border-radius:var(--r);padding:7px 10px;margin-top:10px;display:none}
.entra-row{display:flex;align-items:center;gap:8px;padding:9px 11px;border:1px solid var(--border2);border-radius:var(--r);font-size:13px;cursor:pointer;background:var(--surface);transition:all .1s;font-family:var(--font);font-weight:500}
.entra-row:hover{background:var(--s3)}
.entra-logo{width:18px;height:18px;flex-shrink:0}

/* ── Dashboard ── */
.dash-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-top:14px}
.dcard{background:var(--surface);border:1px solid var(--border);border-radius:var(--r2);padding:16px 18px;box-shadow:var(--sh)}
.dcard-t{font-size:13px;font-weight:600;margin-bottom:12px;display:flex;align-items:center;justify-content:space-between}
.bar-r{display:flex;align-items:center;gap:9px;margin-bottom:8px}
.bar-l{font-size:12px;color:var(--sub);width:96px;flex-shrink:0;text-align:right;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.bar-t{flex:1;height:6px;background:var(--s3);border-radius:3px;overflow:hidden}
.bar-f{height:100%;border-radius:3px;transition:width .65s ease}
.bar-n{font-size:10px;font-family:var(--mono);color:var(--muted);width:22px}
.donut-w{display:flex;align-items:center;gap:18px}
.dleg{display:flex;flex-direction:column;gap:6px;flex:1}
.dleg-r{display:flex;align-items:center;gap:7px;font-size:12px}
.dleg-v{margin-left:auto;font-family:var(--mono);font-size:11px;font-weight:500;color:var(--sub)}
.ldot{width:8px;height:8px;border-radius:50%;flex-shrink:0}
.act-list{display:flex;flex-direction:column;gap:6px}
.act-r{display:flex;align-items:center;gap:9px;padding:7px 9px;background:var(--s3);border-radius:var(--r);font-size:12px}
.act-ico{font-size:15px;width:24px;text-align:center}
.act-txt{flex:1}
.act-txt strong{font-weight:600;display:block;font-size:12px}
.act-txt span{color:var(--muted);font-size:11px}
.top-list{display:flex;flex-direction:column;gap:5px}
.top-r{display:flex;align-items:center;justify-content:space-between;padding:6px 9px;background:var(--s3);border-radius:var(--r);font-size:12px}
.top-r span:last-child{font-family:var(--mono);font-size:10px;color:var(--muted)}

/* ── Config ── */
.ccard{background:var(--surface);border:1px solid var(--border);border-radius:var(--r2);padding:18px;box-shadow:var(--sh);margin-bottom:14px}
.ccard h3{font-size:14px;font-weight:700;margin-bottom:3px}
.ccard p{font-size:13px;color:var(--sub);line-height:1.6;margin-bottom:12px}
.ctag{font-family:var(--mono);font-size:11px;background:var(--blue-l);color:var(--blue);border:1px solid rgba(37,99,235,.2);border-radius:4px;padding:2px 7px;display:inline-block}
.cg{display:grid;grid-template-columns:1fr 1fr;gap:10px}
.step-r{display:flex;gap:11px;padding:7px 0;border-bottom:1px solid var(--border)}
.step-r:last-child{border-bottom:none}
.step-n{width:20px;height:20px;border-radius:50%;background:var(--blue);color:#fff;font-size:10px;font-weight:700;display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:2px}
.step-t{font-size:13px;color:var(--sub);line-height:1.6}

/* ── Toast ── */
.toast{position:fixed;bottom:18px;right:18px;z-index:300;background:var(--surface);border:1px solid var(--border);border-radius:var(--r2);padding:9px 15px;font-size:13px;box-shadow:var(--sh2);display:flex;align-items:center;gap:8px;transform:translateY(50px);opacity:0;transition:all .22s;max-width:280px}
.toast.show{transform:translateY(0);opacity:1}
.toast.ok{border-left:3px solid var(--green)}
.toast.warn{border-left:3px solid var(--amber)}
.toast.err{border-left:3px solid var(--red)}

/* ── Loading ── */
.loading-row td{text-align:center;color:var(--muted);padding:28px;font-size:13px}
.spin{display:inline-block;width:14px;height:14px;border:2px solid var(--border2);border-top-color:var(--blue);border-radius:50%;animation:spin .65s linear infinite;vertical-align:middle;margin-right:7px}
@keyframes spin{to{transform:rotate(360deg)}}
</style>
</head>
<body>

<!-- ══════════════════════════════ AUTH ══════════════════════════════ -->
<div id="auth">
<div class="auth-wrap">
  <div class="auth-head">
    <div class="auth-icon">📦</div>
    <div><div class="auth-title">Inventario IT</div><div class="auth-sub">BD_PC · BD_Perifericos · BD_Telefonos</div></div>
  </div>
  <p class="auth-desc">Conecta con tu tenant de Microsoft 365. La app lee directamente tus listas de SharePoint usando las mismas credenciales que Power Apps.</p>

  <!-- Entra ID SSO (primary) -->
  <div class="entra-row" onclick="loginEntra()">
    <svg class="entra-logo" viewBox="0 0 21 21" fill="none" xmlns="http://www.w3.org/2000/svg">
      <rect width="10" height="10" fill="#F25022"/><rect x="11" width="10" height="10" fill="#7FBA00"/>
      <rect y="11" width="10" height="10" fill="#00A4EF"/><rect x="11" y="11" width="10" height="10" fill="#FFB900"/>
    </svg>
    Iniciar sesión con Microsoft (Entra ID)
  </div>

  <div class="auth-sep">o configuración manual</div>

