function exportCSV() {
  const listId=view==='dash'||view==='cfg'?'pc':view;
  const cfg=LISTS[listId]; const data=DATA[listId]; if(!data||!cfg) return;
  const keys=cfg.fields.map(f=>f.key);
  const hdr=cfg.fields.map(f=>f.label).join(',');
  const rows=data.map(r=>keys.map(k=>`"${(r[k]||'').replace(/"/g,'""')}"`).join(','));
  const csv=[hdr,...rows].join('\n');
  const blob=new Blob(['\uFEFF'+csv],{type:'text/csv;charset=utf-8'});
  const url=URL.createObjectURL(blob);
  const a=document.createElement('a');a.href=url;a.download=`${cfg.name}-${new Date().toISOString().split('T')[0]}.csv`;a.click();URL.revokeObjectURL(url);
  toast(`⬇ ${cfg.name}.csv exportado`,'ok');
}

// ═══════════════════════════════════════════════════════════
// UTILS
// ═══════════════════════════════════════════════════════════
function refreshCounts() {
  const total=Object.values(DATA).reduce((s,arr)=>s+arr.length,0);
  document.getElementById('ct-total').textContent=total;
  Object.keys(LISTS).forEach(k=>{
    const el=document.getElementById('ct-'+k);
    if(el) el.textContent=DATA[k]?.length||0;
  });
}
function cm(id){document.getElementById(id).classList.remove('open')}
function toast(msg,type=''){
  const el=document.getElementById('toast');
  el.className=`toast ${type} show`;el.textContent=msg;
  clearTimeout(el._t);el._t=setTimeout(()=>el.classList.remove('show'),3200);
}
</script>
