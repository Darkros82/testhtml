  const token = await getToken(); if(!token) return;
  try {
    const siteId = await getSiteId(token);
    let url = `https://graph.microsoft.com/v1.0/sites/${siteId}/lists/${encodeURIComponent(cfg.spListName)}/items?expand=fields&$top=999`;
    let all = [];
    while(url) {
      const r = await fetch(url,{headers:{Authorization:`Bearer ${token}`}});
      const d = await r.json(); all = all.concat(d.value||[]); url = d['@odata.nextLink']||null;
    }
    DATA[listId] = all.map(item => {
      const obj = { id: item.id, _spId: item.id };
      cfg.fields.forEach(f => { obj[f.key] = item.fields?.[f.spCol] || ''; });
      return obj;
    });
    refreshCounts();
    if(view===listId) render();
    toast(`✅ ${cfg.name} cargada (${DATA[listId].length} items)`,'ok');
  } catch(e) { toast(`Error cargando ${cfg.name}: ${e.message}`,'err'); }
}
async function loadAllLists() { for(const k of Object.keys(LISTS)) await loadList(k); }
async function getSiteId(token) {
  if(SP._siteId) return SP._siteId;
  const u=SP.siteUrl.replace('https://',''); const [h,...p]=u.split('/');
  const r=await fetch(`https://graph.microsoft.com/v1.0/sites/${h}:/${p.join('/')}`,{headers:{Authorization:`Bearer ${token}`}});
  const d=await r.json(); SP._siteId=d.id; return d.id;
}
async function saveToSP(listId, rec) {
  if(SP.demo) return;
  const token=await getToken(); if(!token) return;
  const cfg=LISTS[listId];
  const fields={};
  cfg.fields.forEach(f=>{ if(f.spCol!=='Title') fields[f.spCol]=rec[f.key]||''; else fields.Title=rec[f.key]||''; });
  const siteId=await getSiteId(token);
  if(rec._spId) {
    await fetch(`https://graph.microsoft.com/v1.0/sites/${siteId}/lists/${encodeURIComponent(cfg.spListName)}/items/${rec._spId}/fields`,{method:'PATCH',headers:{'Authorization':`Bearer ${token}`,'Content-Type':'application/json'},body:JSON.stringify(fields)});
  } else {
    const r=await fetch(`https://graph.microsoft.com/v1.0/sites/${siteId}/lists/${encodeURIComponent(cfg.spListName)}/items`,{method:'POST',headers:{'Authorization':`Bearer ${token}`,'Content-Type':'application/json'},body:JSON.stringify({fields})});
    const d=await r.json(); rec._spId=d.id;
  }
}
async function deleteFromSP(listId, spId) {
  if(SP.demo||!spId) return;
  const token=await getToken(); if(!token) return;
  const cfg=LISTS[listId]; const siteId=await getSiteId(token);
  await fetch(`https://graph.microsoft.com/v1.0/sites/${siteId}/lists/${encodeURIComponent(cfg.spListName)}/items/${spId}`,{method:'DELETE',headers:{Authorization:`Bearer ${token}`}});
}
function syncCurrent() {
  if(SP.demo){toast('Modo demo: no hay SP conectado','warn');return}
  if(view!=='dash'&&view!=='cfg') loadList(view);
}

