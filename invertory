function go(v) {
  view=v; page=1; activeTipos=new Set();
  document.querySelectorAll('.ni').forEach(el=>el.classList.remove('on'));
  const ni=document.getElementById('ni-'+v); if(ni) ni.classList.add('on');
  const cfg=LISTS[v];
  document.getElementById('tb-title').textContent = cfg ? cfg.name : (v==='dash'?'Panel':v==='cfg'?'Configuración':'—');
  document.getElementById('tb-badge').innerHTML = cfg ? `<span class="tb-list-badge">${cfg.spListName}</span>` : '';
  document.getElementById('add-btn').style.display = (v==='dash'||v==='cfg') ? 'none' : 'flex';
  buildFilterBar(v);
  render();
}
function buildFilterBar(v) {
  const fbar = document.getElementById('fbar');
  const cfg = LISTS[v];
  if(!cfg||!cfg.filterValues) { fbar.style.display='none'; return; }
  fbar.style.display='flex';
  fbar.innerHTML = `<span class="fbar-lbl">Tipo:</span>
    ${cfg.filterValues.map(val=>`<div class="fchip on" data-v="${val}" onclick="toggleTipo('${val}')">${val}</div>`).join('')}
    <div class="spc"></div>
    <select class="fsel" id="f-user" onchange="render()"><option value="">Todos los usuarios</option>${[...new Set(DATA[v].map(r=>r.titulo).filter(Boolean))].sort().map(u=>`<option>${u}</option>`).join('')}</select>`;
  cfg.filterValues.forEach(v => activeTipos.add(v));
}
function toggleTipo(t) {
  activeTipos.has(t)?activeTipos.delete(t):activeTipos.add(t);
  document.querySelectorAll('.fchip').forEach(el=>el.classList.toggle('on',activeTipos.has(el.dataset.v)));
  page=1; render();
}

// ═══════════════════════════════════════════════════════════
// RENDER
// ═══════════════════════════════════════════════════════════
function render() {
  if(view==='dash'){renderDash();return}
  if(view==='cfg'){renderCfg();return}
  const cfg=LISTS[view]; if(!cfg) return;
  let data=[...DATA[view]];
  const q=(document.getElementById('q')?.value||'').toLowerCase();
  if(q) data=data.filter(r=>JSON.stringify(r).toLowerCase().includes(q));
  if(cfg.filterValues && activeTipos.size) data=data.filter(r=>activeTipos.has(r.tipo));
  const fu=document.getElementById('f-user')?.value||'';
  if(fu) data=data.filter(r=>r.titulo===fu);
  data=data.sort((a,b)=>{const av=(a[sortKey]||'').toString().toLowerCase(),bv=(b[sortKey]||'').toString().toLowerCase();return av<bv?-sortDir:av>bv?sortDir:0});
  const total=data.length, pages=Math.max(1,Math.ceil(total/PER));
  if(page>pages)page=1;
  const slice=data.slice((page-1)*PER,page*PER);

  // Which fields to show as columns (first 6 non-note fields)
  const cols=cfg.fields.filter(f=>f.type!=='note').slice(0,7);

  document.getElementById('content').innerHTML=`
    <div class="tc">
      <table>
        <thead><tr>
          ${cols.map(f=>`<th class="${sortKey===f.key?'sk':''}" onclick="sortBy('${f.key}')">${f.label} ${sortKey===f.key?(sortDir>0?'↑':'↓'):''}</th>`).join('')}
          <th></th>
        </tr></thead>
        <tbody>
          ${slice.length===0?`<tr><td colspan="${cols.length+1}"><div class="empty"><div class="ei">🔍</div>No se encontraron registros</div></td></tr>`:
            slice.map(r=>`<tr>
              ${cols.map((f,i)=>`<td>${renderCell(f,r,i===0)}</td>`).join('')}
              <td><div class="row-acts">
                <button class="ib" title="Ver detalle" onclick="viewRec('${r.id}','${view}')">👁</button>
                <button class="ib" title="Editar" onclick="openEdit('${r.id}','${view}')">✏</button>
                <button class="ib del" title="Eliminar" onclick="delRec('${r.id}','${view}')">🗑</button>
              </div></td>
            </tr>`).join('')
          }
        </tbody>
      </table>
      <div class="pager">
        <span>${total} registros · pág. ${page}/${pages}</span>
        <div class="pager-btns">
          <button class="pb" onclick="changePg(${page-1})" ${page<=1?'disabled':''}>‹</button>
          ${Array.from({length:Math.min(pages,7)},(_,i)=>i+1).map(p=>`<button class="pb ${p===page?'on':''}" onclick="changePg(${p})">${p}</button>`).join('')}
          <button class="pb" onclick="changePg(${page+1})" ${page>=pages?'disabled':''}>›</button>
        </div>
      </div>
    </div>`;
}
function renderCell(f,r,isPrimary) {
  const val=r[f.key]||'';
  if(!val&&!isPrimary) return '<span style="color:var(--muted)">—</span>';
  if(f.bitlocker&&val) return `<span class="bitlocker-tag" title="${val}">🔒 ${val.slice(0,12)}…</span>`;
  if(f.badge&&val) return `<span class="tipo-chip tipo-${val.replace(/\s/g,'-')}">${val}</span>`;
  if(f.mono&&val) return `<span style="font-family:var(--mono);font-size:12px">${val}</span>`;
  if(isPrimary) return `<div class="cell-name">${val}${r.nombreEquipo?`<small>${r.nombreEquipo}</small>`:''}</div>`;
  if(f.type==='date'&&val) return `<span style="font-size:12px;color:var(--sub)">${val.split('T')[0]||val}</span>`;
  return `<span style="font-size:13px">${val}</span>`;
}
function sortBy(k){sortKey===k?sortDir*=-1:(sortKey=k,sortDir=1);render()}
function changePg(p){const data=DATA[view]||[];const pages=Math.max(1,Math.ceil(data.length/PER));if(p<1||p>pages)return;page=p;render()}

